# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
# Leave as-is when using the bundled postgres container
DATABASE_URL=postgres://joule:joule@postgres:5432/joule?sslmode=disable

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: openai | anthropic
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com   # Change for Ollama, Azure, OpenRouter, etc.

# Anthropic (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Override the default model (optional)
# openai default: gpt-4o
# anthropic default: claude-sonnet-4-6
AI_MODEL=

# Tavily API key — enables web search in the AI coach (optional)
# Also required for the lookup_nutrition agent tool to fall back to web search
TAVILY_API_KEY=

# ── OCR ───────────────────────────────────────────────────────────────────────
# Set to "tesseract" to use the built-in Tesseract OCR for food photo analysis.
# When set, Tesseract extracts text from images first (great for nutrition labels),
# then the AI parses the extracted text instead of processing the full image.
# This reduces vision API costs and improves label-reading accuracy.
# Leave empty to use the default AI vision model for all image analysis.
OCR_PROVIDER=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Without SMTP, verification codes are printed to Docker logs instead
SMTP_HOST=
SMTP_PORT=587   # 465 = implicit TLS, 587 = STARTTLS
SMTP_USER=
SMTP_PASS=

# ── Admin ─────────────────────────────────────────────────────────────────────
# First user created with this email becomes admin
ADMIN_EMAIL=admin@joule.local
# Required — set a strong password before running for the first time
ADMIN_PASSWORD=

# Set to true to require admin approval before new users can log in
REQUIRE_APPROVAL=false

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# A mailto: or https: contact URL, sent to push relay servers
VAPID_CONTACT=mailto:you@yourdomain.com

# ── ntfy (optional) ───────────────────────────────────────────────────────────
# Base URL of your ntfy server. Users can set a personal topic in their
# notification preferences for reliable delivery even when the browser is closed.
NTFY_BASE_URL=
NTFY_TOKEN=              # Publisher token from: ntfy token add joules-publisher
