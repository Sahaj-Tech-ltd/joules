# ── Required ──────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/joules
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
ADMIN_EMAIL=admin@example.com

# ── AI — Chat/Text (OpenAI or OpenAI-compatible) ────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com

# ── AI — Models ──────────────────────────────────────────
AI_MODEL=gpt-4o-mini
ROUTING_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini
OCR_MODEL=gpt-4o-mini
CLASSIFIER_MODEL=gpt-4o-mini

# ── AI — Per-role provider overrides (leave empty to use global) ──
# Set these to route vision/OCR/classifier to a different OpenAI-compatible
# endpoint (e.g., DeepInfra). If empty, the global OPENAI_* settings are used.
# VISION_API_KEY=
# VISION_BASE_URL=
# OCR_API_KEY=
# OCR_BASE_URL=
# CLASSIFIER_API_KEY=
# CLASSIFIER_BASE_URL=

# ── OCR ──────────────────────────────────────────────────
# OCR_PROVIDER=tesseract

# ── Web Push (VAPID) ─────────────────────────────────────
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@example.com

# ── ntfy (optional) ──────────────────────────────────────
# NTFY_BASE_URL=https://ntfy.sh
# NTFY_TOKEN=

# ── SMTP (optional) ──────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ── Google Fit (optional) ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Misc ─────────────────────────────────────────────────
PORT=3000
APP_URL=http://localhost:3000
UPLOAD_DIR=./uploads
REQUIRE_APPROVAL=false
